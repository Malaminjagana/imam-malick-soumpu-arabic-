    <!-- Normalize CMS content: strip inline styles, replace font tags, wrap tables -->
    <script>
        document.querySelectorAll('.nds-block').forEach(section => {
            // Strip inline styles (keep custom props)
            section.querySelectorAll('[style]').forEach(el => {
                var raw = el.getAttribute('style') || '';
                var kept = raw.split(';').map(function(s){return s.trim();}).filter(function(s){return s.startsWith('--');});
                if (kept.length) el.setAttribute('style', kept.join(';'));
                else el.removeAttribute('style');
            });
            // Replace <font> with <span>
            section.querySelectorAll('font').forEach(f => {
                const s = document.createElement('span');
                s.innerHTML = f.innerHTML;
                f.replaceWith(s);
            });
            // Remove empty <p>, <p> with only <br>s, and standalone <br>
            section.querySelectorAll('p').forEach(p => {
                if (!p.textContent.trim() && [...p.children].every(c => c.tagName === 'BR')) p.remove();
            });
            section.querySelectorAll('br').forEach(br => br.remove());
            // Wrap tables
            section.querySelectorAll('table').forEach(t => {
                t.classList.add('nds-table', 'nds-responsive');
                const w = document.createElement('div');
                w.className = 'nds-table-wrapper';
                t.parentNode.insertBefore(w, t);
                w.appendChild(t);
            });
        });
    </script>
    
    
    
