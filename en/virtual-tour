    var links = menu.querySelectorAll('.nds-drawer-list a.nds-indicator');
    for (var i = 0; i < links.length; i++) {
        var href = decodeURIComponent(links[i].getAttribute('href') || '');
        if (href && href !== '#' && path === href) {
            var li = links[i].closest('li');
            links[i].setAttribute('data-state', 'active');
            if (li) li.setAttribute('data-state', 'active');
            var parentUl = li ? li.parentElement : null;
            var parentLi = parentUl ? parentUl.closest('li') : null;
            if (parentLi && parentLi.parentElement.closest('.nds-drawer-list')) {
                parentLi.setAttribute('data-state', 'open');
                var btn = parentLi.querySelector(':scope > button');
                if (btn) {
                    btn.setAttribute('data-state', 'open');
                    btn.setAttribute('aria-expanded', 'true');
                }
            }
        }
    }
})();
</script>




