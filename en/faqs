        <script>
        (function () {
            // tag-id → NDS color (preserved from the previous hardcoded mapping).
            const TAG_COLORS = {
                'new-student': 'green', 'female': 'purple', 'international': 'blue',
                'employees': 'yellow', 'registration': 'blue', 'schedule': 'yellow',
                'fees': 'green', 'eligibility': 'red', 'exams': 'red',
                'transfer': 'purple', 'deferral': 'purple', 'documents': 'gray',
                'overview': 'gray'
            };

            // Pick the AR or EN side of any { ar, en } object based on the live
            // <html lang>. Prefer NDS.isArabic (shared core, reads the same source);
            // the html-lang readback is a fallback for environments where the NDS
            // bundle hasn't loaded yet or pre-dates that getter.
            function localized(o) {
                if (!o) return '';
                const isAr = (window.NDS && typeof NDS.isArabic !== 'undefined')
                    ? NDS.isArabic
                    : (document.documentElement.lang || '').toLowerCase().startsWith('ar');
                return o[isAr ? 'ar' : 'en'] || o.ar || o.en || '';
            }

            // NDS.escapeHtml (nds-core) — textContent-based; safer than ad-hoc regex.
            const escapeHtml = s => (window.NDS && NDS.escapeHtml) ? NDS.escapeHtml(s) : String(s ?? '');

            // Minimal markdown: \n paragraphs, "- " unordered lists, [text](url)
            // links, **bold**. Inline transforms run on already-escaped text, so
            // the [ ] ( ) markers survive (escapeHtml only touches & < > " ').
            // Emitted <a> elements are plain — NDS.Link.init() (called after
            // render) tags them with nds-link / nds-external / target / rel.
            function renderMd(text) {
                if (!text) return '';
                const lines = String(text).split('\n');
                let out = '', para = [], inList = false;
                const inline = s => s
                    .replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, '<a href="https://iu.edu.sa/en/$2">$1</a>')
                    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
                const flushPara = () => { if (para.length) { out += '<p>' + inline(para.join(' ')) + '</p>'; para = []; } };
                const flushList = () => { if (inList) { out += '</ul>'; inList = false; } };
                for (const raw of lines) {
                    const t = raw.trim();
                    if (!t) { flushPara(); flushList(); continue; }
                    if (t.startsWith('- ')) {
                        flushPara();
                        if (!inList) { out += '<ul>'; inList = true; }
                        out += '<li>' + inline(escapeHtml(t.slice(2))) + '</li>';
                    } else {
                        flushList();
                        para.push(escapeHtml(t));
                    }
                }
                flushPara(); flushList();
                return out;
            }

            function buildTagsHtml(tagIds, tagMap) {
                if (!tagIds || !tagIds.length) return '';
                const chips = tagIds.map(id => {
                    const t = tagMap.get(id);
                    if (!t) return '';
                    const color = TAG_COLORS[id] || 'gray';
                    return '<span class="nds-tag nds-' + color + ' nds-sm">' +
                        '<span class="nds-label" data-filter="tag">' + escapeHtml(t.label) + '</span>' +
                        '</span>';
                }).join('');
                return chips ? '<div class="nds-tags nds-chips">' + chips + '</div>' : '';
            }

            function buildAccordionItem(faq, tabKey, tagMap) {
                const headerId = 'faq-' + tabKey + '-h-' + faq.id;
                const collapseId = 'faq-' + tabKey + '-c-' + faq.id;
                return '<div class="nds-accordion-item">' +
                        '<h3 class="nds-accordion-header" id="' + headerId + '">' +
                            '<button class="nds-btn nds-subtle nds-menu-btn nds-accordion-btn" type="button" ' +
                                'aria-expanded="false" aria-controls="' + collapseId + '">' +
                                '<span class="nds-accordion-title">' + escapeHtml(localized(faq.question)) + '</span>' +
                            '</button>' +
                        '</h3>' +
                        '<div class="nds-accordion-collapse" id="' + collapseId + '" aria-labelledby="' + headerId + '">' +
                            '<div class="nds-accordion-content">' +
                                '<div class="nds-accordion-body">' +
                                    renderMd(localized(faq.answer)) +
                                    buildTagsHtml(faq.tags, tagMap) +
                                '</div>' +
                            '</div>' +
                        '</div>' +
                    '</div>';
            }

            function buildTabButton(tab, isActive) {
                const id = tab.id;
                return '<button class="nds-btn nds-subtle nds-tab" role="tab" ' +
                    'aria-selected="' + (isActive ? 'true' : 'false') + '" ' +
                    'aria-controls="panel-faq-' + id + '" id="tab-faq-' + id + '" ' +
                    'tabindex="' + (isActive ? '0' : '-1') + '">' +
                    '<span class="nds-label">' + escapeHtml(localized(tab.label)) + '</span>' +
                    '</button>';
            }

            function buildTabPanel(tab, faqs, tagMap, isActive) {
                const id = tab.id;
                const itemsId = 'faq-' + id + '-items';
                const filterAttr = id === 'all' ? ' data-filter-items=".nds-accordion-item"' : '';
                const tabFaqs = id === 'all' ? faqs : faqs.filter(f => f.tab === id);
                const items = tabFaqs.map(f => buildAccordionItem(f, id, tagMap)).join('');
                return '<div class="nds-tab-panel" role="tabpanel" id="panel-faq-' + id + '" ' +
                        'aria-labelledby="tab-faq-' + id + '"' +
                        (isActive ? '' : ' aria-hidden="true"') +
                        ' tabindex="' + (isActive ? '0' : '-1') + '"' +
                        (isActive ? '' : ' hidden') + '>' +
                        '<div class="nds-accordion nds-lg" id="' + itemsId + '"' + filterAttr + '>' +
                            items +
                        '</div>' +
                    '</div>';
            }

            function wireSwitchToAll() {
                const searchBox = document.querySelector('.nds-search-box[data-filter-target="faq-all-items"]');
                const filterDropmenu = document.querySelector('.nds-filter[data-filter-target="faq-all-items"]');
                const allTabBtn = document.getElementById('tab-faq-all');
                if (!allTabBtn) return;

                function switchToAll() {
                    if (allTabBtn.getAttribute('aria-selected') === 'true') return;
                    allTabBtn.click();
                }

                const searchInput = document.getElementById('faqSearch');
                if (searchInput) searchInput.addEventListener('input', switchToAll);
                if (searchBox) {
                    searchBox.addEventListener('click', function (e) {
                        if (e.target.closest('.nds-search-btn, .nds-clear, .nds-voice-input')) switchToAll();
                    });
                }
                if (filterDropmenu) {
                    filterDropmenu.addEventListener('click', function (e) {
                        if (e.target.closest('[data-filter-action="apply"]')) switchToAll();
                    });
                }
            }

            // Attach a typeahead to the FAQ search input that draws from the
            // same in-memory dataset. We deliberately skip auto-init by leaving
            // data-url and autocomplete="on" off the markup, then create the
            // instance ourselves with a custom filter (bilingual match across
            // question + answer) and renderItem (highlighted question text).
            // The instance's cache is pre-seeded, so it never fetches.
            function wireAutocomplete(data) {
                const container = document.querySelector('.nds-search-box[data-filter-target="faq-all-items"]');
                const input = document.getElementById('faqSearch');
                if (!container || !input || !window.NDS || !NDS.Autocomplete) return;

                container.setAttribute('data-fetch', 'once');
                container.setAttribute('data-name', '_displayText'); // selectItem writes this to the input
                container.setAttribute('data-min-chars', '2');
                input.setAttribute('autocomplete', 'on');

                const reEscape = s => String(s).replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

                const instance = NDS.Autocomplete.create(container, {
                    filter(items, query) {
                        const q = String(query || '').toLowerCase().trim();
                        if (!q) return [];
                        const out = [];
                        for (const it of items) {
                            const blob = (
                                (it.question && it.question.ar || '') + ' ' +
                                (it.question && it.question.en || '') + ' ' +
                                (it.answer && it.answer.ar || '') + ' ' +
                                (it.answer && it.answer.en || '')
                            ).toLowerCase();
                            if (blob.indexOf(q) === -1) continue;
                            it._displayText = localized(it.question);
                            out.push(it);
                        }
                        return out;
                    },
                    renderItem(item, query) {
                        const text = escapeHtml(localized(item.question));
                        if (!query) return text;
                        const re = new RegExp('(' + reEscape(escapeHtml(String(query))) + ')', 'gi');
                        return text.replace(re, '<mark>$1</mark>');
                    }
                });
                if (!instance) return;
                // Reuse the JSON we already fetched — skip the autocomplete's own network call.
                instance.cache = data.faqs || [];
            }

            // When the user applies tag filters, the tab navigation becomes
            // irrelevant — the filter only operates on the All-tab accordion,
            // so any other tab would show unfiltered content. Hide the tab list
            // and force the All tab active while filters are on.
            //
            // The filter component toggles the `hidden` attribute on
            // .nds-filter-applied based on whether any filters are active —
            // we observe that single signal instead of intercepting apply/clear/
            // chip-removal individually.
            function wireFilterTabsHide() {
                const appliedSel = '.nds-filter-applied[data-filter-target="faq-all-items"]';
                const applied = document.querySelector(appliedSel);
                const tabsListContainer = document.querySelector('#faq-tabs .nds-tab-list-container');
                const allTabBtn = document.getElementById('tab-faq-all');
                if (!applied || !tabsListContainer) return;

                function update() {
                    const filterActive = !applied.hasAttribute('hidden');
                    // Inline style beats any [hidden]-overriding CSS the tab-list-container
                    // picks up from NDS layout rules.
                    tabsListContainer.style.display = filterActive ? 'none' : '';
                    if (filterActive && allTabBtn && allTabBtn.getAttribute('aria-selected') !== 'true') {
                        allTabBtn.click();
                    }
                }

                update();
                // Share the process-wide attribute observer instead of spinning up
                // our own. NDS.onAttrChange fans out by selector + attribute name.
                if (window.NDS && NDS.onAttrChange) {
                    NDS.onAttrChange(appliedSel, ['hidden'], update);
                }
            }

            function render(data) {
                const tabsContainer = document.getElementById('faq-tabs');
                if (!tabsContainer) return;
                const nav = tabsContainer.querySelector('.nds-tab-list');
                const content = tabsContainer.querySelector('.nds-tab-content');
                if (!nav || !content) return;

                // Flatten audience + topic tags into one id → { label } lookup.
                const tagMap = new Map();
                const tagsRoot = data.tags || {};
                [].concat(tagsRoot.audience || [], tagsRoot.topic || [])
                    .forEach(t => tagMap.set(t.id, { label: localized(t.label) }));

                const tabs = data.tabs || [];
                const faqs = data.faqs || [];

                nav.innerHTML = tabs.map((t, i) => buildTabButton(t, i === 0)).join('');
                content.innerHTML = tabs.map((t, i) => buildTabPanel(t, faqs, tagMap, i === 0)).join('');

                // Re-initialize NDS components that own the newly added DOM.
                //
                // The tabs/filter containers ship with data-nds-*-initialized="true" so
                // auto-init at page load skips them (their inner structure is still empty
                // at that point — auto-init would warn "Invalid tab structure" / "No values
                // found for filter tag"). Now that the DOM is populated, clear the marker
                // and call init() to bind a real instance.
                if (window.NDS) {
                    if (NDS.Tabs) {
                        tabsContainer.removeAttribute('data-nds-tabs-initialized');
                        NDS.Tabs.init && NDS.Tabs.init();
                    }
                    NDS.Accordion && NDS.Accordion.reinit && NDS.Accordion.reinit();
                    // Tag links inside answers (added after page-load auto-init ran)
                    // with nds-link / nds-external / target / rel. init() is idempotent.
                    NDS.Link && NDS.Link.init && NDS.Link.init();
                    if (NDS.Filter) {
                        const filterEl = document.querySelector('.nds-filter[data-filter-target="faq-all-items"]');
                        if (filterEl) filterEl.removeAttribute('data-nds-filter-initialized');
                        NDS.Filter.init && NDS.Filter.init();
                        const filter = NDS.Filter.getByTarget && NDS.Filter.getByTarget('faq-all-items');
                        if (filter) {
                            filter.refresh();
                        } else if (NDS.Filter.whenReady) {
                            NDS.Filter.whenReady('.nds-filter[data-filter-target="faq-all-items"]', f => f.refresh());
                        }
                    }
                }

                wireSwitchToAll();
                wireAutocomplete(data);
                wireFilterTabsHide();
            }

            // Read the bilingual dataset inlined above as <script id="faqsData">.
            const dataEl = document.getElementById('faqsData');
            if (!dataEl) {
                console.error('FAQs load failed: #faqsData element not found');
                return;
            }
            let data;
            try {
                data = JSON.parse(dataEl.textContent);
            } catch (err) {
                console.error('FAQs parse failed:', err);
                return;
            }

            // The data is now available synchronously (no network round-trip),
            // but render() initializes NDS components (Tabs/Accordion/Filter), so
            // it must wait until the NDS bundle has executed — otherwise the
            // `if (window.NDS)` guards inside render() silently no-op and the tabs
            // never switch. The previous fetch() masked this by resolving late.
            // Wait for DOMContentLoaded, then poll briefly for window.NDS; render
            // anyway after ~5s so a missing bundle still shows the static content.
            function boot() {
                let waited = 0;
                (function waitForNDS() {
                    if (window.NDS || waited >= 5000) { render(data); return; }
                    waited += 50;
                    setTimeout(waitForNDS, 50);
                })();
            }
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', boot);
            } else {
                boot();
            }
        })();
        </script>
    </div>
</div>

