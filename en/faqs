                <div class="nds-progress-info"><span class="nds-progress-steps"></span></div>
            </div>
            <!-- Step 1: Student Type -->
            <div class="nds-stepper-step">
                <div class="nds-stepper-base">
                    <div class="nds-stepper-circle" data-step-text="1"></div>
