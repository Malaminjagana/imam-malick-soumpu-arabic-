    <script>
    (function() {
        var bc = document.querySelector('.nds-breadcrumb');
        if (!bc) return;
        var items = bc.querySelectorAll('li');

        // mark active nav link from 2nd breadcrumb item
        var secondLi = items[1];
        if (secondLi) {
            var bcText = (secondLi.textContent || '').trim();
            if (bcText) {
                var navLinks = document.querySelectorAll('.nds-nav-primary .nds-nav-link');
                for (var i = 0; i < navLinks.length; i++) {
                    var label = navLinks[i].querySelector('.nds-label');
                    var labelText = label ? (label.textContent || '').trim() : '';
                    if (labelText && (labelText === bcText || bcText.indexOf(labelText) !== -1 || labelText.indexOf(bcText) !== -1)) {
                        navLinks[i].setAttribute('data-state', 'current');
                        break;
                    }
                }
            }
        }

        // inject BreadcrumbList JSON-LD
        if (!items.length) return;
        var origin = window.location.origin;
        var listItems = [];
        for (var pos = 0; pos < items.length; pos++) {
            var a = items[pos].querySelector('a');
            var name = (a ? a.textContent : items[pos].textContent || '').trim();
            if (!name) continue;
            var entry = { '@type': 'ListItem', position: listItems.length + 1, name: name };
            if (a && a.href) entry.item = a.href.indexOf('http') === 0 ? a.href : origin + a.getAttribute('href');
            listItems.push(entry);
        }
        if (listItems.length < 2) return;
        var ld = document.createElement('script');
        ld.type = 'application/ld+json';
        ld.text = JSON.stringify({ '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: listItems });
        document.head.appendChild(ld);
    })();
    </script>
